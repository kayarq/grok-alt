#!/usr/bin/env bash
# grok-alt — launch the Grok trace companion TUI (or tmux / list / …).
set -euo pipefail

# Resolve install root. Symlinks from ~/.local/bin must follow the real
# script path — otherwise ROOT becomes ~/.local and the left tmux pane dies
# with "No module named grok_alt" / missing textual+rich.
_grok_alt_root() {
  if [[ -n "${GROK_ALT_HOME:-}" ]]; then
    cd "$GROK_ALT_HOME" && pwd
    return
  fi
  local src="$1" dir
  # Prefer physical path of this launcher (works for PATH symlinks).
  if command -v readlink >/dev/null 2>&1; then
    local resolved
    resolved="$(readlink -f "$src" 2>/dev/null || true)"
    if [[ -n "$resolved" && -e "$resolved" ]]; then
      src="$resolved"
    else
      # macOS / older readlink: walk symlinks manually
      while [[ -L "$src" ]]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src" || true)"
        [[ "$src" != /* ]] && src="$dir/$src"
      done
      src="$(cd -P "$(dirname "$src")" && pwd)/$(basename "$src")"
    fi
  fi
  cd "$(dirname "$src")/.." && pwd
}

ROOT="$(_grok_alt_root "$0")"
VENV="$ROOT/.venv"
PY="$VENV/bin/python3"

if [[ ! -x "$PY" ]]; then
  echo "grok-alt: venv missing at $VENV" >&2
  echo "  (resolved install root: $ROOT)" >&2
  echo "  Run:  cd \"$ROOT\" && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
  exit 1
fi

export GROK_ALT_HOME="$ROOT"
export PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$PY" -m grok_alt "$@"
